function s:hdevtools_options(rgs)
	return join(map(a:rgs, "'-g ' . v:val"))
endfunction

let g:syntastic_haskell_hdevtools_args = s:hdevtools_options
	\ (
	\ [ '-ilib'
	\ , '-ibin'
	\ , '-itest'
	\ , '-idist/build/autogen'
	\ , '-DTEST'
	\ , '-O0'
	\ , '-fdefer-type-errors'
	\ , '-Wall'
	\ ]
	\ )

let g:vim_flipping_substitutions =
	\ { 'lib/(.+)(\.l?hs)':      'test/\1Spec\2'
	\ , 'test/(.+)Spec(\.l?hs)': 'lib/\1\2'
	\ }
